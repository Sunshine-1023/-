DEEPSEEK_API_KEY=sk-在这里填入你的真实DeepSeek密钥
# 可选配置
# CHROMA_DB_DIR=./chroma_db
# BGE_DEVICE=mps  # 可选: mps/cpu/cuda，根据环境选择
# BGE_LOCAL_FILES_ONLY=0  # 1=仅使用本地缓存，0=允许联网下载模型
# HF_ENDPOINT=https://hf-mirror.com
# LLM_TIMEOUT_SECONDS=15
# LLM_MAX_RETRIES=2
# AUTO_USE_SYSTEM_PROXY=0  # 默认关闭，避免错误代理导致 DeepSeek 失败
# LLM_TRUST_ENV_PROXY=0     # LLM 客户端忽略系统代理（推荐）
